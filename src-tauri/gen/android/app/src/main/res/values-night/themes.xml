<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.app" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <!-- These are ignored on Android 15+ (mandatory edge-to-edge); effective on older versions -->
        <item name="android:statusBarColor">@color/status_bar_color_night</item>
        <item name="android:navigationBarColor">@color/status_bar_color_night</item>
        <item name="android:windowLightStatusBar">false</item> <!-- dark bg -> light icons -->
    </style>
</resources>
